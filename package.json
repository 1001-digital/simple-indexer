{
  "name": "@1001-digital/simple-indexer",
  "version": "0.1.0",
  "description": "Lightweight, reorg-aware EVM indexer that runs in both browser and server contexts.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sqlite": {
      "import": "./dist/sqlite.js",
      "types": "./dist/sqlite.d.ts"
    }
  },
  "files": [
    "dist",
    "examples"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "viem": ">=2.0.0",
    "better-sqlite3": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "viem": "^2.23.0",
    "better-sqlite3": "^11.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0",
    "fake-indexeddb": "^6.0.0",
    "prettier": "^3.8.1"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
