# Copy to .env and fill in your RPC details.

RPC_URL=https://ethereum-rpc.publicnode.com
CHAIN=mainnet
STORE=memory

# Optional: only needed if STORE=sqlite
SQLITE_PATH=./opepen-artifacts.db

# Optional: only needed if STORE=idb
IDB_NAME=opepen-artifacts

# Optional: set this once you know the contract deployment block
START_BLOCK=21930000
END_BLOCK=21938955
